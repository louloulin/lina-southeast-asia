// ============================================================
// LINA — 跨境电商 MVP 数据库架构
// Cross-border E-commerce MVP Database Schema (Prisma)
// ============================================================
// 支持：多币种结算 | 东南亚多语言 | 多国家扩展
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum PaymentMethod {
  CARD
  GRABPAY
  GOPAY
  OVO
  PROMPTPAY
  BANK_TRANSFER
  COD
}

enum SourcePlatform {
  ALI_1688
  ALI_EXPRESS
  TAOBAO
}

// ============================================================
// COUNTRY / 国家配置
// ============================================================

model Country {
  id           String  @id @default(cuid())
  code         String  @unique // ISO 3166-1 alpha-2: SG, MY, TH, ID, PH, VN
  name         String
  nameZh       String?
  isActive     Boolean @default(true)
  currencyCode String
  currency     Currency @relation(fields: [currencyCode], references: [code])
  languageCodes String[]
  taxRate      Decimal @default(0) @db.Decimal(5, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
  users  User[]

  @@index([code])
}

// ============================================================
// CURRENCY / 货币配置
// ============================================================

model Currency {
  code          String   @id // ISO 4217: USD, SGD, MYR, THB, IDR, VND, CNY
  name          String
  symbol        String
  decimalPlaces Int      @default(2)
  isActive      Boolean  @default(true)
  rateToUsd     Decimal  @default(1) @db.Decimal(18, 8)
  updatedAt     DateTime @updatedAt

  countries Country[]
  orders    Order[]
  payments  Payment[]

  @@index([code])
}

// ============================================================
// LANGUAGE / 语言配置
// ============================================================

model Language {
  code       String  @id // ISO 639-1: en, zh, ms, th, id, vi, tl
  name       String
  nativeName String
  isActive   Boolean @default(true)
  isDefault  Boolean @default(false)
  sortOrder  Int     @default(0)

  translations          Translation[]
  productTranslations   ProductTranslation[]
  categoryTranslations  CategoryTranslation[]

  @@index([code])
}

// ============================================================
// USER / 用户
// ============================================================

model User {
  id                String  @id @default(cuid())
  email             String  @unique
  phone             String?
  name              String?
  avatar            String?

  // 认证
  authProvider      String? // google, apple, phone
  authProviderId    String?

  // 设置
  preferredCurrency String? @default("USD")
  preferredLanguage String  @default("en")
  countryCode       String?
  country           Country? @relation(fields: [countryCode], references: [code])

  // 角色
  role     String  @default("customer") // customer, admin, seller
  isActive Boolean @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  addresses Address[]
  orders    Order[]

  @@index([email])
  @@index([countryCode])
}

// ============================================================
// ADDRESS / 收货地址
// ============================================================

model Address {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  recipientName String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String?
  postalCode   String?
  countryCode  String
  country      Country? @relation(fields: [countryCode], references: [code])

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// CATEGORY / 商品分类
// ============================================================

model Category {
  id        String  @id @default(cuid())
  slug      String  @unique
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  translations CategoryTranslation[]
  products     Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

// ============================================================
// CATEGORY_TRANSLATION / 分类翻译
// ============================================================

model CategoryTranslation {
  id           String   @id @default(cuid())
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  languageCode String
  language     Language @relation(fields: [languageCode], references: [code])

  name        String
  description String?

  @@unique([categoryId, languageCode])
  @@index([languageCode])
}

// ============================================================
// PRODUCT / 商品
// ============================================================

model Product {
  id             String         @id @default(cuid())
  sourceId       String?        // 1688商品ID
  sourceUrl      String?
  sourcePlatform SourcePlatform  @default(ALI_1688)

  slug        String   @unique
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  priceCny    Decimal @db.Decimal(10, 2)

  isActive    Boolean @default(true)
  isFeatured  Boolean @default(false)
  stockStatus String  @default("in_stock")

  viewCount   Int      @default(0)
  orderCount  Int      @default(0)
  rating      Decimal? @db.Decimal(3, 2)
  ratingCount Int      @default(0)

  images        ProductImage[]
  translations  ProductTranslation[]
  variants      ProductVariant[]
  orderItems    OrderItem[]

  rawAttributes Json? // 1688原始规格属性

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([sourceId])
}

// ============================================================
// PRODUCT_TRANSLATION / 商品翻译
// ============================================================

model ProductTranslation {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  languageCode String
  language     Language @relation(fields: [languageCode], references: [code])

  name        String
  description String?  @db.Text
  shortDesc   String?  @db.VarChar(500)

  metaTitle   String?
  metaDesc    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, languageCode])
  @@index([languageCode])
}

// ============================================================
// PRODUCT_IMAGE / 商品图片
// ============================================================

model ProductImage {
  id           String  @id @default(cuid())
  productId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url          String
  alt          String?
  sortOrder    Int     @default(0)
  isPrimary    Boolean @default(false)

  thumbnailUrl String?
  mediumUrl    String?

  createdAt DateTime @default(now())

  @@index([productId])
}

// ============================================================
// PRODUCT_VARIANT / SKU变体
// ============================================================

model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku         String  @unique
  name        String?
  sourceSkuId String?

  priceCny    Decimal @db.Decimal(10, 2)
  attributes  Json?

  stockQty    Int     @default(0)
  isActive    Boolean @default(true)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
}

// ============================================================
// ORDER / 订单
// ============================================================

model Order {
  id              String  @id @default(cuid())
  orderNumber     String  @unique // LINA-20240101-XXXXX

  userId          String
  user            User    @relation(fields: [userId], references: [id])

  shippingAddressId String?
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  countryCode    String
  country        Country  @relation(fields: [countryCode], references: [code])
  currencyCode   String
  currency       Currency @relation(fields: [currencyCode], references: [code])

  // 当地货币金额
  subtotal       Decimal @db.Decimal(12, 2)
  shippingCost   Decimal @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  // USD 等值（财务核算用）
  subtotalUsd    Decimal @db.Decimal(12, 2)
  totalAmountUsd Decimal @db.Decimal(12, 2)

  status         OrderStatus @default(PENDING)

  customerNote   String? @db.Text

  payment        Payment?

  trackingNumber  String?
  shippingCarrier String?
  shippedAt       DateTime?
  deliveredAt     DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?

  orderItems OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([countryCode])
}

// ============================================================
// ORDER_ITEM / 订单项
// ============================================================

model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productSnapshot Json // {name, image, sku, attributes}

  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================================
// PAYMENT / 支付记录
// ============================================================

model Payment {
  id       String  @id @default(cuid())
  orderId  String  @unique
  order    Order   @relation(fields: [orderId], references: [id])

  amount       Decimal @db.Decimal(12, 2)
  currencyCode String
  currency     Currency @relation(fields: [currencyCode], references: [code])

  amountPaid Decimal? @db.Decimal(12, 2)

  method     PaymentMethod
  methodName String?

  paymentIntentId String?
  thirdPartyRef   String?

  status PaymentStatus @default(PENDING)

  refundedAmount Decimal? @db.Decimal(12, 2)
  refundReason   String?
  refundedAt     DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?

  @@index([orderId])
  @@index([status])
}

// ============================================================
// TRANSLATION / 通用翻译表
// ============================================================

model Translation {
  id           String   @id @default(cuid())

  entityType   String   // product, category, brand, page, system
  entityId     String

  languageCode String
  language     Language @relation(fields: [languageCode], references: [code])

  field        String   // name, description, button, label...
  value        String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId, languageCode, field])
  @@index([entityType, entityId])
  @@index([languageCode])
}

// ============================================================
// CURRENCY_RATE / 汇率记录
// ============================================================

model CurrencyRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(18, 8)
  recordedAt   DateTime @default(now())

  @@index([fromCurrency, toCurrency, recordedAt(sort: Desc)])
}

// ============================================================
// CART / 购物车
// ============================================================

model Cart {
  id           String  @id @default(cuid())
  userId       String? @unique
  sessionId    String?
  countryCode  String
  currencyCode String

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}

model CartItem {
  id           String @id @default(cuid())
  cartId       String
  cart         Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId    String
  variantId    String?

  quantity     Int    @default(1)

  unitPriceCny Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}
